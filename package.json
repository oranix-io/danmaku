{
  "name": "live-hime",
  "version": "1.0.0",
  "main": "dist/main/index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "build": "tsx build.ts && yarn renderer:build",
    "dev": "wireit",
    "watch": "tsx build.ts --watch",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "renderer:dev": "wireit",
    "renderer:build": "yarn workspace renderer-react build"
  },
  "wireit": {
    "renderer:dev": {
      "command": "yarn workspace renderer-react dev",
      "service": true
    },
    "dev": {
      "command": "electron-forge start",
      "service": true,
      "dependencies": [
        "renderer:dev"
      ]
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dotenv": "^17.4.2",
    "electron": "^41.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "filesize": "^11.0.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "lodash": "^4.18.1",
    "mri": "^1.2.0",
    "undici": "^8.1.0",
    "update-electron-app": "^3.1.2",
    "vite": "^8.0.10",
    "wireit": "^0.14.12",
    "ws": "^8.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:bytemain/danmaku.git"
  },
  "packageManager": "yarn@3.6.0",
  "workspaces": [
    "renderer"
  ],
  "engines": {
    "node": ">=20.19.0"
  }
}
